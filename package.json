{
  "name": "piggy-pulse",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "api:generate": "openapi-typescript ./openapi.yaml -o src/api/v2.d.ts",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run eslint && npm run stylelint",
    "eslint": "eslint . --cache",
    "stylelint": "stylelint '**/*.css' --cache",
    "prettier": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "vitest": "vitest run",
    "vitest:watch": "vitest",
    "vitest:storybook": "vitest run --config vitest.storybook.config.ts",
    "test": "npm run typecheck && npm run prettier && npm run lint && npm run vitest && npm run build",
    "tests": "npm run test",
    "e2e": "playwright test",
    "e2e:local:mock": "E2E_TARGET=local E2E_API_MODE=mock playwright test --project=desktop-chromium --project=mobile-chromium",
    "e2e:local:real": "E2E_TARGET=local E2E_API_MODE=real playwright test --project=desktop-chromium --project=mobile-chromium",
    "e2e:docker:mock": "E2E_TARGET=docker E2E_BASE_URL=https://localhost:18443 E2E_API_MODE=mock playwright test --project=desktop-chromium --project=mobile-chromium",
    "e2e:docker:real": "E2E_TARGET=docker E2E_BASE_URL=https://localhost:18443 E2E_API_MODE=real E2E_API_URL=http://127.0.0.1:18080 playwright test --project=desktop-chromium --project=mobile-chromium",
    "e2e:docker:up": "bash scripts/test-env-up.sh",
    "e2e:docker:down": "bash scripts/test-env-down.sh",
    "e2e:docker:reset": "bash scripts/test-env-reset.sh",
    "e2e:screenshots": "E2E_TARGET=local E2E_API_MODE=mock playwright test tests/screenshots/screenshots.spec.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test-storybook": "vitest --config vitest.storybook.config.ts",
    "install-browsers": "npx playwright install"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/charts": "^8.3.18",
    "@mantine/core": "^8.3.16",
    "@mantine/dates": "^8.3.17",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.15",
    "@mantine/notifications": "^8.3.17",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.90.21",
    "@vitest/browser-playwright": "^4.1.2",
    "dayjs": "^1.11.20",
    "emoji-picker-react": "^4.18.0",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.13",
    "openapi-fetch": "^0.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.8",
    "react-is": "^19.2.3",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@storybook/addon-themes": "10.2.13",
    "@storybook/addon-vitest": "10.1.11",
    "@storybook/react": "10.2.14",
    "@storybook/react-vite": "10.3.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.1",
    "@types/react-is": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.0.17",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "4.1.1",
    "eslint": "^9.39.2",
    "eslint-config-mantine": "^4.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "prop-types": "^15.8.1",
    "storybook": "10.2.10",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "yarn@4.12.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "resolutions": {
    "minimatch": "^3.1.4",
    "minimatch@^3.1.2": "3.1.4",
    "minimatch@^10.1.2": "10.2.4",
    "rollup": "^4.59.0",
    "flatted": "^3.4.2",
    "tar": "^7.5.11",
    "picomatch": "^4.0.4"
  }
}
